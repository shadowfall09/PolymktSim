\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Overview of the \textbf  {InfoDelphi} framework. (a)\nobreakspace  {}\textbf  {Evidence Routing}: documents are ranked by BM25 relevance and distributed round-robin, constructing a shared public pool and disjoint private subsets for each agent. (b)\nobreakspace  {}\textbf  {Multi-Agent Deliberation}: agents exchange structured forecasts and rationales over two rounds, enabling private information to propagate. (c)\nobreakspace  {}\textbf  {Calibrated Aggregation}: final-round forecasts are averaged and passed through an asymmetric shrinkage transform toward a NO-leaning prior $p_0$, correcting systematic overconfidence.}}{5}{figure.caption.7}\protected@file@percent }
\newlabel{fig:arch}{{2}{5}{Overview of the \textbf {InfoDelphi} framework. (a)~\textbf {Evidence Routing}: documents are ranked by BM25 relevance and distributed round-robin, constructing a shared public pool and disjoint private subsets for each agent. (b)~\textbf {Multi-Agent Deliberation}: agents exchange structured forecasts and rationales over two rounds, enabling private information to propagate. (c)~\textbf {Calibrated Aggregation}: final-round forecasts are averaged and passed through an asymmetric shrinkage transform toward a NO-leaning prior $p_0$, correcting systematic overconfidence}{figure.caption.7}{}}
\newlabel{eq:agent}{{5}{5}{Iterative Deliberation with Rationale Sharing}{equation.3.5}{}}
