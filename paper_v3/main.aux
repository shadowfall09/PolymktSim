\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Main results on \textsc  {PolyGym}-250 and FutureX-231. All methods use \texttt  {gpt-5.4-mini} over the same fixed pre-resolution evidence pools. $\dagger $: InfoDelphi (full) is significantly better under a paired bootstrap over questions (5{,}000 resamples; 95\% CI of the Brier difference excludes 0; Appendix Table\nobreakspace  {}\ref  {tab:significance}). Best in \textbf  {bold}.}}{7}{table.caption.17}\protected@file@percent }
\newlabel{tab:main}{{1}{7}{Main results on \textsc {PolyGym}-250 and FutureX-231. All methods use \texttt {gpt-5.4-mini} over the same fixed pre-resolution evidence pools. $\dagger $: InfoDelphi (full) is significantly better under a paired bootstrap over questions (5{,}000 resamples; 95\% CI of the Brier difference excludes 0; Appendix Table~\ref {tab:significance}). Best in \textbf {bold}}{table.caption.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Component ablation (Brier$\,\downarrow $). Each row removes one component from the full system. ``$-$ asymmetry'' gives every agent the full evidence pool ($\rho {=}1$, full sharing) with the same calibrated prompt, i.e., the Standard Debate configuration of our pipeline. Paired 95\% CIs for each removal are given in the text.}}{7}{table.caption.21}\protected@file@percent }
\newlabel{tab:ablation}{{2}{7}{Component ablation (Brier$\,\downarrow $). Each row removes one component from the full system. ``$-$ asymmetry'' gives every agent the full evidence pool ($\rho {=}1$, full sharing) with the same calibrated prompt, i.e., the Standard Debate configuration of our pipeline. Paired 95\% CIs for each removal are given in the text}{table.caption.21}{}}
