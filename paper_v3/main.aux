\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Control experiment: applying our calibrated-shrink transform ($p_0{=}0.30$, $w_{\mathrm  {lo}}{=}0.8$, $w_{\mathrm  {hi}}{=}0.5$) to every baseline's output. Shrinkage improves all methods; the ranking is preserved and InfoDelphi remains best on both datasets, although several pairwise gaps are no longer individually significant (n.s.). $\Delta $ is the paired Brier difference of InfoDelphi (full) vs.\ the shrunk baseline (negative favors ours).}}{15}{table.caption.50}\protected@file@percent }
\newlabel{tab:shrink_control}{{5}{15}{Control experiment: applying our calibrated-shrink transform ($p_0{=}0.30$, $w_{\mathrm {lo}}{=}0.8$, $w_{\mathrm {hi}}{=}0.5$) to every baseline's output. Shrinkage improves all methods; the ranking is preserved and InfoDelphi remains best on both datasets, although several pairwise gaps are no longer individually significant (n.s.). $\Delta $ is the paired Brier difference of InfoDelphi (full) vs.\ the shrunk baseline (negative favors ours)}{table.caption.50}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Paired bootstrap comparison of InfoDelphi (full) against each baseline (5{,}000 resamples over questions, seed 0). $\Delta $Brier $<0$ favors InfoDelphi; all 95\% CIs exclude zero.}}{15}{table.caption.51}\protected@file@percent }
\newlabel{tab:significance}{{6}{15}{Paired bootstrap comparison of InfoDelphi (full) against each baseline (5{,}000 resamples over questions, seed 0). $\Delta $Brier $<0$ favors InfoDelphi; all 95\% CIs exclude zero}{table.caption.51}{}}
